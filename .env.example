# UNICHE IdP — local/dev configuration.
# Copy to `.env` and adjust. NEVER commit `.env` (it is git-ignored).
# In staging/prod these values come from the orchestrator's secret store, not a file.

# --- Keycloak admin bootstrap (DEV throwaway credentials) ---
KC_ADMIN=admin
KC_ADMIN_PASSWORD=admin

# --- Keycloak database ---
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak

# --- Published host ports (change to avoid clashes when several components run on one machine) ---
IDP_HTTP_PORT=8081
IDP_DB_PORT=5433

# --- ECCCH AAI federation (FS-IAM-02) ---
# Shipped DISABLED with placeholder endpoints in realm/uniche-realm.json.
# Real endpoints/secret are per-deployment; see README "Enabling ECCCH AAI".
# ECCCH_CLIENT_ID=
# ECCCH_CLIENT_SECRET=
# ECCCH_ISSUER=
